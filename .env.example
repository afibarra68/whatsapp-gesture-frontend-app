# =============================================================================
# WhatsApp Control — Frontend (Vite)
# =============================================================================
# Copia:  cp .env.example .env
# Local:  npm run dev
# Build:  variables embebidas en el bundle (configurar en CI / Vercel / DO)
# =============================================================================

# --- API (obligatoria en producción) ---
# Sin slash final. Local: http://localhost:3000/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# --- Branding (pantalla de login y menú lateral) ---
VITE_EVENT_NAME=WhatsApp Control
VITE_EVENT_SHORT=WA
VITE_EVENT_TAGLINE=Panel de mensajería
